{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/dist/**",
      "*.md",
      "*.pdf",
      "storage.rules",
      "package-lock.json",
      "functions/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/Home.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  }
}
